  margin-bottom: 2rem;
}

.hero-meta {
  display: flex;
  gap: 2rem;
  font-family: var(--mono);
  font-size: 0.75rem;
  color: var(--text-dim);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-top: 3rem;
}

.hero-meta span strong {
  color: var(--text-muted);
  font-weight: 500;
  display: block;
  margin-top: 0.3rem;
  font-size: 0.85rem;
  letter-spacing: 0.05em;
}

section {
