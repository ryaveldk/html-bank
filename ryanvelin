      <text x="265" y="150" font-family="Newsreader" font-style="italic" font-size="11" fill="#a89f93" text-anchor="middle">Cast bredt → snæver progressivt → giv LLM'en det bedste</text>

      <defs>
        <marker id="arrK" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
