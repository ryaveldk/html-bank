  margin-top: 0.8rem;
}

.card {
  background: var(--bg-card);
  border: 1px solid var(--line);
  border-radius: 6px;
  padding: 1.5rem 1.8rem;
  margin: 1.5rem 0;
}

.card.warning { border-left: 3px solid var(--warning); }
.card.success { border-left: 3px solid var(--success); }
.card.note { border-left: 3px solid var(--accent); }

.card-label {
  font-family: var(--mono);
  font-size: 0.7rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 0.7rem;
}

.card.warning .card-label { color: var(--warning); }
.card.success .card-label { color: var(--success); }

.card p:last-child { margin-bottom: 0; }

details.deep-dive {
  margin: 2rem 0;
  background: var(--bg-elevated);
  border: 1px solid var(--line);
  border-radius: 6px;
  overflow: hidden;
  transition: border-color 0.2s ease;
}

details.deep-dive[open] { border-color: var(--accent-dim); }

details.deep-dive summary {
  padding: 1rem 1.5rem;
  cursor: pointer;
  font-family: var(--mono);
  font-size: 0.78rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--accent);
  list-style: none;
  display: flex;
  align-items: center;
  justify-content: space-between;
  user-select: none;
  transition: background 0.15s ease;
}

details.deep-dive summary:hover { background: var(--bg-card-hover); }
details.deep-dive summary::-webkit-details-marker { display: none; }

details.deep-dive summary::after {
  content: "+";
  font-size: 1.2rem;
  font-family: var(--display);
  color: var(--accent);
  transition: transform 0.2s ease;
}

details.deep-dive[open] summary::after { content: "−"; }

details.deep-dive .deep-content {
  padding: 0 1.5rem 1.5rem 1.5rem;
  border-top: 1px solid var(--line);
  padding-top: 1.5rem;
}

details.deep-dive .deep-content p:last-child { margin-bottom: 0; }

.nudge {
  margin: 2rem 0;
  padding: 1.2rem 1.5rem;
  background: linear-gradient(135deg, rgba(200, 118, 66, 0.06), rgba(200, 118, 66, 0.02));
  border: 1px solid rgba(200, 118, 66, 0.2);
  border-radius: 6px;
  display: flex;
  gap: 1.2rem;
  align-items: flex-start;
}

.nudge-icon {
  font-family: var(--display);
  font-style: italic;
  font-size: 1.6rem;
  color: var(--accent);
  line-height: 1;
  flex-shrink: 0;
  margin-top: -2px;
}

.nudge-body {
  font-size: 0.95rem;
  color: var(--text-muted);
  line-height: 1.55;
}

.nudge-body strong {
  display: block;
  color: var(--accent-bright);
  font-family: var(--mono);
  font-size: 0.7rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  font-weight: 500;
  margin-bottom: 0.4rem;
}

.compare {
  margin: 2rem 0;
  border: 1px solid var(--line);
  border-radius: 6px;
  overflow: hidden;
}

.compare-row {
  display: grid;
  grid-template-columns: 180px 1fr;
  border-bottom: 1px solid var(--line);
}

.compare-row:last-child { border-bottom: none; }

.compare-row.header {
  background: var(--bg-elevated);
  font-family: var(--mono);
  font-size: 0.72rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--accent);
}

.compare-cell {
  padding: 0.9rem 1.3rem;
  border-right: 1px solid var(--line);
  font-size: 0.92rem;
  line-height: 1.5;
}

.compare-cell:last-child { border-right: none; }

.compare-cell.label {
  font-family: var(--mono);
  font-size: 0.78rem;
  color: var(--text-muted);
  background: rgba(0,0,0,0.1);
}

.diagram {
  margin: 2.5rem 0;
  padding: 2rem;
  background: var(--bg-elevated);
  border: 1px solid var(--line);
  border-radius: 6px;
  text-align: center;
}

.diagram svg { max-width: 100%; height: auto; }

.diagram-caption {
  font-family: var(--mono);
  font-size: 0.72rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
  margin-top: 1.2rem;
}

.glossary-grid { display: grid; gap: 1.2rem; }

.glossary-item {
  padding: 1.2rem 1.5rem;
  background: var(--bg-card);
  border: 1px solid var(--line);
  border-radius: 6px;
  scroll-margin-top: 2rem;
  transition: all 0.3s ease;
}

.glossary-item:target {
  border-color: var(--accent);
  background: var(--bg-card-hover);
  box-shadow: 0 0 0 4px rgba(200, 118, 66, 0.08);
}

.glossary-term {
  font-family: var(--display);
  font-weight: 500;
  font-size: 1.15rem;
  color: var(--accent-bright);
  margin-bottom: 0.5rem;
  letter-spacing: -0.01em;
}

.glossary-term .pronounce {
  font-family: var(--mono);
  font-size: 0.7rem;
  font-weight: 400;
  letter-spacing: 0.1em;
