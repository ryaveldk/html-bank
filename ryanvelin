}

h2 {
  font-family: var(--display);
  font-weight: 400;
  font-size: 2.4rem;
  line-height: 1.15;
  letter-spacing: -0.015em;
  margin-bottom: 2rem;
  color: var(--text);
}

h2 em { font-style: italic; color: var(--accent); }

h3 {
  font-family: var(--display);
  font-weight: 500;
  font-size: 1.4rem;
