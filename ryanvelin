}

.glossary-def {
  color: var(--text-muted);
  font-size: 0.95rem;
  line-height: 1.55;
}

.resource-list { display: grid; gap: 1rem; margin-top: 2rem; }

.resource {
  display: block;
  padding: 1.3rem 1.5rem;
